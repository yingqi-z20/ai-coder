{
  "name": "ai-coder-thucs",
  "displayName": "AI Coder - THUCS",
  "description": "AI Coder for Vivado",
  "version": "0.1.0",
	"publisher": "YingqiZhang",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Debuggers",
    "Programming Languages"
  ],
	"repository": {
		"type": "git",
		"url": "https://github.com/yingqi-z20/ai-coder"
	},
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-coder",
          "title": "ai-coder",
          "icon": "media/robot.svg"
        }
      ]
    },
    "views": {
      "ai-coder": [
        {
          "type": "webview",
          "id": "webpage",
          "name": "chat",
          "icon": "media/robot.svg",
          "contextualTitle": "AI Coder"
        }
      ]
    },
    "commands": [
      {
        "command": "ai-coder.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}